#!/usr/bin/env python3
"""
Vision Manager Script

Changelog:
- v1.2.1 (2025-09-21)
  * Legacy switch: probe live mode for PRIMARY (no service stop) and update fields if known.
  * Two-camera switch: also probe SECONDARY and ensure resolution/fps/format are written,
    plus default PiP params. Removes [secondary] entirely when not provided.
  * No other behavior changes. Added --version.

- v1.2.0
  * Earlier iteration of switching logic.

- v1.1.0
  * Hardened switching.

- v1.0.0
  * Baseline you shared.
"""

__version__ = "v1.2.1"

import subprocess
import os
import sys
import argparse
import re
from typing import Optional, Tuple
from configparser import ConfigParser

CONFIG_FILE = "/etc/vision_streaming.conf"
TEMP_FILE = "/tmp/vision_streaming.conf"
SERVICE_NAME = "vision_streaming.service"

# ---------------- Core helpers ----------------

def control_service(action: str) -> None:
    try:
        subprocess.run(['sudo', 'systemctl', action, SERVICE_NAME], check=True)
        print(f"Service {action}ed successfully.")
    except subprocess.CalledProcessError as e:
        print(f"Failed to {action} service: {e}")
        sys.exit(1)

def validate_device(device: str) -> None:
    if not os.path.exists(device):
        print(f"Error: Device {device} does not exist.")
        sys.exit(1)

def get_current_mode_safe(device: str) -> Tuple[Optional[str], Optional[str], Optional[str]]:
    """
    Probe live V4L2 mode without stopping the service.
    Returns (resolution_str, fps_str, fmt_str) or (None, None, None).
    Matches:
      Width/Height : 640/480
      Pixel Format : 'MJPG'  OR Pixel Format FourCC : 'MJPG'
      Frames per second: 120.000  OR Frame rate: 120.000
    """
    res, fps, fmt = None, None, None
    try:
        out = subprocess.run(
            ['v4l2-ctl', '--device', device, '--get-fmt-video'],
            capture_output=True, text=True, check=False
        )
        if out.returncode == 0:
            m_res = re.search(r'Width/Height\s*:\s*(\d+)\s*/\s*(\d+)', out.stdout)
            m_fmt = re.search(r"Pixel Format(?: FourCC)?\s*:\s*'(\w+)'", out.stdout)
            if m_res:
                res = f"{m_res.group(1)}x{m_res.group(2)}"
            if m_fmt:
                fmt = m_fmt.group(1)

        out2 = subprocess.run(
            ['v4l2-ctl', '--device', device, '--get-parm'],
            capture_output=True, text=True, check=False
        )
        if out2.returncode == 0:
            m_fps = re.search(r'(?:Frame rate|Frames per second)\s*:\s*([\d\.]+)', out2.stdout)
            if m_fps:
                fps = m_fps.group(1).split('.')[0]
    except Exception:
        pass
    return res, fps, fmt

# --------------- Legacy switch ---------------

def edit_camera_config(primary_device: str, secondary_device: Optional[str] = None) -> None:
    """
    Legacy mode switch:
      - Probe live mode for PRIMARY; update fields if known (no service stop).
      - Update [primary].camera_name; keep bitrate if already set (else default).
      - If ONE device: REMOVE [secondary] section entirely (no comments).
      - If TWO devices: CREATE/UPDATE [secondary] and also PROBE it to fill
        resolution/fps/format (plus PiP defaults), so the node always has complete values.
      - Restart service to apply changes.
    """
    validate_device(primary_device)
    if secondary_device:
        validate_device(secondary_device)

    cfg = ConfigParser(strict=False)
    if os.path.exists(CONFIG_FILE):
        cfg.read(CONFIG_FILE)
    else:
        cfg.add_section('general')
        cfg['general']['rtp_ip'] = '127.0.0.1'
        cfg['general']['rtp_port'] = '5602'

    if not cfg.has_section('general'):
        cfg.add_section('general')
        if 'rtp_ip' not in cfg['general']:
            cfg['general']['rtp_ip'] = '127.0.0.1'
        if 'rtp_port' not in cfg['general']:
            cfg['general']['rtp_port'] = '5602'

    if not cfg.has_section('primary'):
        cfg.add_section('primary')

    # Probe live primary mode
    p_res, p_fps, p_fmt = get_current_mode_safe(primary_device)

    # Update primary
    cfg['primary']['camera_name'] = primary_device
    if p_res:
        cfg['primary']['resolution'] = p_res
    if p_fps:
        cfg['primary']['fps'] = p_fps
    if p_fmt:
        cfg['primary']['format'] = p_fmt
    if not cfg.has_option('primary', 'bitrate'):
        cfg['primary']['bitrate'] = '3000K'

    # Secondary handling: add/remove section (no commenting). Also probe secondary to ensure it is complete.
    if secondary_device:
        if not cfg.has_section('secondary'):
            cfg.add_section('secondary')
        cfg['secondary']['camera_name'] = secondary_device

        # Probe and fill secondary mode so node won't crash in PiP
        s_res, s_fps, s_fmt = get_current_mode_safe(secondary_device)
        if s_res:
            cfg['secondary']['resolution'] = s_res
        if s_fps:
            cfg['secondary']['fps'] = s_fps
        if s_fmt:
            cfg['secondary']['format'] = s_fmt

        # PiP defaults
        if not cfg.has_option('secondary', 'pip_position'):
            cfg['secondary']['pip_position'] = 'bottom-right'
        if not cfg.has_option('secondary', 'pip_size'):
            cfg['secondary']['pip_size'] = '240x180'
        if not cfg.has_option('secondary', 'bitrate'):
            cfg['secondary']['bitrate'] = '2000K'
    else:
        if cfg.has_section('secondary'):
            cfg.remove_section('secondary')

    # Atomic write
    with open(TEMP_FILE, 'w') as f:
        cfg.write(f)
    subprocess.run(['sudo', 'cp', TEMP_FILE, CONFIG_FILE], check=True)
    subprocess.run(['sudo', 'rm', TEMP_FILE], check=True)
    print("Configuration file updated from live camera probe.")
    control_service('restart')

# ----------------------------- (unchanged helpers) -----------------------------

def update_resolution_only_config(device, resolution):
    validate_device(device)
    try:
        subprocess.run(['sudo', 'cp', CONFIG_FILE, TEMP_FILE], check=True)
        subprocess.run(['sudo', 'chmod', '666', TEMP_FILE], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Error copying config file: {e}")
        sys.exit(1)
    with open(TEMP_FILE, "r") as file:
        lines = file.readlines()
    in_target = False
    new_lines = []
    res_updated = False
    for line in lines:
        stripped = line.strip()
        if stripped.startswith('[') and stripped.endswith(']'):
            if in_target and not res_updated:
                new_lines.append(f"resolution = {resolution}\n")
                res_updated = True
            in_target = False
            new_lines.append(line)
            continue
        if "camera_name" in line and device in line:
            in_target = True
        if in_target and stripped.lstrip('#').startswith("resolution"):
            new_lines.append(f"resolution = {resolution}\n")
            res_updated = True
        else:
            new_lines.append(line)
    if in_target and not res_updated:
        new_lines.append(f"resolution = {resolution}\n")
    try:
        with open(TEMP_FILE, "w") as file:
            file.writelines(new_lines)
        subprocess.run(['sudo', 'cp', TEMP_FILE, CONFIG_FILE], check=True)
        subprocess.run(['sudo', 'rm', TEMP_FILE], check=True)
        print("Configuration file updated successfully with new resolution.")
    except subprocess.CalledProcessError as e:
        print(f"Error updating config file: {e}")
        sys.exit(1)
    control_service('restart')

def update_cam_params_config(device, resolution, fps, cam_format):
    validate_device(device)
    try:
        subprocess.run(['sudo', 'cp', CONFIG_FILE, TEMP_FILE], check=True)
        subprocess.run(['sudo', 'chmod', '666', TEMP_FILE], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Error copying config file: {e}")
        sys.exit(1)
    with open(TEMP_FILE, "r") as file:
        lines = file.readlines()
    in_target = False
    new_lines = []
    res_updated = False
    fps_updated = False
    format_updated = False
    for line in lines:
        stripped = line.strip()
        if stripped.startswith('[') and stripped.endswith(']'):
            if in_target:
                if not res_updated:
                    new_lines.append(f"resolution = {resolution}\n")
                if not fps_updated:
                    new_lines.append(f"fps = {fps}\n")
                if not format_updated:
                    new_lines.append(f"format = {cam_format}\n")
            in_target = False
            new_lines.append(line)
            continue
        if "camera_name" in line and device in line:
            in_target = True
            new_lines.append(line)
            continue
        if in_target:
            if stripped.lstrip('#').startswith("resolution"):
                new_lines.append(f"resolution = {resolution}\n")
                res_updated = True
            elif stripped.lstrip('#').startswith("fps"):
                new_lines.append(f"fps = {fps}\n")
                fps_updated = True
            elif stripped.lstrip('#').startswith("format"):
                new_lines.append(f"format = {cam_format}\n")
                format_updated = True
            else:
                new_lines.append(line)
        else:
            new_lines.append(line)
    if in_target:
        if not res_updated:
            new_lines.append(f"resolution = {resolution}\n")
        if not fps_updated:
            new_lines.append(f"fps = {fps}\n")
        if not format_updated:
            new_lines.append(f"format = {cam_format}\n")
    try:
        with open(TEMP_FILE, "w") as file:
            file.writelines(new_lines)
        subprocess.run(['sudo', 'cp', TEMP_FILE, CONFIG_FILE], check=True)
        subprocess.run(['sudo', 'rm', TEMP_FILE], check=True)
        print("Configuration file updated successfully with new camera parameters.")
    except subprocess.CalledProcessError as e:
        print(f"Error updating config file: {e}")
        sys.exit(1)
    control_service('restart')

def set_resolution_only(device, resolution):
    validate_device(device)
    try:
        width, height = resolution.split('x')
    except Exception:
        print("Invalid resolution format. Use e.g., 1920x1080.")
        sys.exit(1)
    control_service('stop')
    try:
        result = subprocess.run(['v4l2-ctl', '--device=' + device, '--get-fmt-video'],
                                  capture_output=True, text=True, check=True)
        output = result.stdout
        m = re.search(r"Pixel Format\s+:\s+'(\w+)'", output)
        if m:
            current_format = m.group(1)
        else:
            print("Unable to determine current pixel format.")
            sys.exit(1)
    except subprocess.CalledProcessError as e:
        print("Error querying current camera format:", e)
        sys.exit(1)
    try:
        cmd = ['sudo', 'v4l2-ctl', '--device=' + device,
               '--set-fmt-video=width=' + width + ',height=' + height + ',pixelformat=' + current_format]
        subprocess.run(cmd, check=True)
        print(f"Camera updated: resolution set to {resolution} using pixel format {current_format}.")
    except subprocess.CalledProcessError as e:
        print("Error setting camera resolution:", e)
        sys.exit(1)
    update_resolution_only_config(device, resolution)
    control_service('restart')

def set_cam_params(device, resolution, fps, fmt):
    validate_device(device)
    try:
        width, height = resolution.split('x')
    except Exception:
        print("Invalid resolution format. Use e.g., 1920x1080.")
        sys.exit(1)
    control_service('stop')
    try:
        cmd = ['sudo', 'v4l2-ctl', '--device=' + device,
               '--set-fmt-video=width=' + width + ',height=' + height + ',pixelformat=' + fmt]
        subprocess.run(cmd, check=True)
        cmd_fps = ['sudo', 'v4l2-ctl', '--device=' + device, '--set-parm=' + str(fps)]
        subprocess.run(cmd_fps, check=True)
        print(f"Camera updated: resolution {resolution}, fps {fps}, format {fmt}.")
    except subprocess.CalledProcessError as e:
        print("Error setting camera parameters:", e)
        sys.exit(1)
    update_cam_params_config(device, resolution, fps, fmt)
    control_service('restart')

def list_details(device):
    validate_device(device)
    print("=== v4l2-ctl Details ===")
    try:
        result = subprocess.run(['v4l2-ctl', '--device=' + device, '--all'],
                                  capture_output=True, text=True, check=True)
        print(result.stdout)
    except subprocess.CalledProcessError as e:
        print("Error querying v4l2-ctl details:", e)
    print("=== udevadm Details ===")
    try:
        result = subprocess.run(['udevadm', 'info', '--query=all', '--name=' + device],
                                  capture_output=True, text=True, check=True)
        print(result.stdout)
    except subprocess.CalledProcessError as e:
        print("Error querying udevadm details:", e)
    print("=== Supported Formats ===")
    try:
        result = subprocess.run(['v4l2-ctl', '--device=' + device, '--list-formats-ext'],
                                  capture_output=True, text=True, check=True)
        print(result.stdout)
    except subprocess.CalledProcessError as e:
        print("Error querying supported formats:", e)

# --------------------------------- CLI ---------------------------------

def main():
    # Legacy mode: if first argument is not one of the new subcommands,
    # assume legacy behavior.
    if len(sys.argv) > 1 and sys.argv[1] not in {"set-resolution-only", "set-cam-params", "list-details", "--version", "-V"}:
        if len(sys.argv) < 2:
            print("Usage: vision_config_manager <primary_device> [secondary_device]")
            sys.exit(1)
        primary_device = sys.argv[1]
        secondary_device = sys.argv[2] if len(sys.argv) > 2 else None
        edit_camera_config(primary_device, secondary_device)
        return

    parser = argparse.ArgumentParser(
        description="Vision Manager App with camera parameter controls"
    )
    parser.add_argument('--version', '-V', action='version', version=__version__)
    subparsers = parser.add_subparsers(dest="command", required=True)

    # Subcommand: set-resolution-only
    parser_res_only = subparsers.add_parser("set-resolution-only", help="Set only the resolution for a camera")
    parser_res_only.add_argument("device", help="Video device (e.g. /dev/video0)")
    parser_res_only.add_argument("resolution", help="Desired resolution (e.g. 1920x1080)")

    # Subcommand: set-cam-params
    parser_cam_params = subparsers.add_parser("set-cam-params", help="Set resolution, fps, and format for a camera")
    parser_cam_params.add_argument("device", help="Video device (e.g. /dev/video0)")
    parser_cam_params.add_argument("resolution", help="Desired resolution (e.g. 1920x1080)")
    parser_cam_params.add_argument("fps", help="Desired fps (e.g. 60)")
    parser_cam_params.add_argument("--format", required=True, help="Video format (e.g. MJPG)")

    # Subcommand: list-details
    parser_list_details = subparsers.add_parser("list-details", help="Display detailed information for a camera including supported formats")
    parser_list_details.add_argument("device", help="Video device (e.g. /dev/video0)")

    args = parser.parse_args()
    if args.command == "set-resolution-only":
        set_resolution_only(args.device, args.resolution)
    elif args.command == "set-cam-params":
        set_cam_params(args.device, args.resolution, args.fps, args.format)
    elif args.command == "list-details":
        list_details(args.device)

if __name__ == "__main__":
    main()
