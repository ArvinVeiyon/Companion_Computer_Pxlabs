[Unit]
Description=TFmini ROS 2 Node
After=network.target

[Service]
User=roz
Environment="source /opt/ros/jazzy/setup.bash"
Environment="source /home/roz/ros2_ws/install/setup.bash"
ExecStart=/usr/bin/env bash -c 'source /opt/ros/jazzy/setup.bash && source /home/roz/ros2_ws/install/setup.bash && ros2 run tfmini_sensor tfmini_node'
Restart=always
WorkingDirectory=/home/roz/ros2_ws

[Install]
WantedBy=multi-user.target
