# /etc/systemd/system/rc_control_node.service
[Unit]
Description=RC Control (camera + shutdown) Node
After=network.target

[Service]
User=roz
# Single‐line ExecStart avoids quoting issues
ExecStart=/usr/bin/env bash -lc "source /opt/ros/jazzy/setup.bash && source /home/roz/ros2_ws/install/setup.bash && ros2 run rc_control rc_control_node"
Restart=always
WorkingDirectory=/home/roz/ros2_ws

[Install]
WantedBy=multi-user.target

