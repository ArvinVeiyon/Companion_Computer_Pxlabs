[Unit]
Description= Ros2 px4 translation node 
After=network.target

[Service]
User=roz
ExecStart=/usr/bin/env bash -c 'source /opt/ros/jazzy/setup.bash && source /home/roz/ros2_ws/install/setup.bash && ros2 run translation_node translation_node_bin'
Restart=always
WorkingDirectory=/home/roz/ros2_ws

[Install]
WantedBy=multi-user.target







