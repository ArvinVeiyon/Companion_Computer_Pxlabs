[Unit]
Description=ROS 2 Vision Streaming Node
After=network.target

[Service]
User=roz
ExecStart=/usr/bin/env bash -c 'source /opt/ros/jazzy/setup.bash && source /home/roz/ros2_ws/install/setup.bash && ros2 run vision_streaming vision_streaming_node'
Restart=always
WorkingDirectory=/home/roz/ros2_ws

[Install]
WantedBy=multi-user.target
