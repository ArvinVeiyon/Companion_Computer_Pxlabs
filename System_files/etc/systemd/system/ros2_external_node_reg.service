[Unit]
Description=ROS 2 External Rover Node
After=network.target

[Service]
User=roz
ExecStart=/usr/bin/env bash -c 'source /opt/ros/jazzy/setup.bash && source /home/roz/ros2_ws/install/setup.bash && ros2 run rov_ext_cpp rov_ext && ros2 run rov_ext_cpp rov_ext && ros2 run rov_collision_stop_cpp rov_collision_stop'
Restart=always
WorkingDirectory=/home/roz/ros2_ws

[Install]
WantedBy=multi-user.target
